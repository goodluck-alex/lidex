OX_API_KEY=your-0x-api-key

# Comma-separated browser origins allowed to call the API with credentials (CORS).
# Must include your Next.js origin(s), e.g. https://app.example.com
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Session cookie: Secure flag defaults to true when NODE_ENV=production.
# Override: COOKIE_SECURE=true|false
# Optional: COOKIE_DOMAIN=.example.com

# Rate limits (per IP): auth = 15 min window; swap quote/execute = 1 min window
# RATE_LIMIT_AUTH_MAX=30
# RATE_LIMIT_SWAP_QUOTE_MAX=45
# RATE_LIMIT_SWAP_EXECUTE_MAX=30

# Hybrid mode: callers must send header `X-Lidex-Mode: dex` or `cex` (or cookie `lidex_mode` on same site).
# DEX-only: /v1/swap/*, /v1/referral/ledger/confirm. CEX/internal: /v1/markets/candles, /v1/fees/*, /v1/pairs.
# Shared (any mode): /v1/markets/pairs, /v1/markets/stats, /v1/referral/* except confirm. /v1/auth/* has no mode gate.

# Platform fee (0x Swap API v2 integrator fee)
# 50 bps = 0.5%
SWAP_FEE_RECIPIENT=0xYourFeeWalletAddress
SWAP_FEE_BPS=50
# Choose ONE: buyToken or sellToken
SWAP_FEE_TOKEN=buyToken

