# PostgreSQL (Prisma). Example: postgresql://USER:PASSWORD@localhost:5432/lidex?schema=public
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/lidex?schema=public

OX_API_KEY=your-0x-api-key

# --- 0x HTTP hardening (recommended for production) ---
# SWAP_QUOTE_CACHE_MS=15000
# OX_HTTP_TIMEOUT_MS=8000
# OX_HTTP_RETRIES=2
# Quote-step cache (frontend quote -> execute). In-memory, best-effort.
# SWAP_QUOTE_SESSION_CACHE_MS=20000
# Hash algorithm for requestHash (sha256 recommended)
# SWAP_QUOTE_REQUEST_HASH_ALGO=sha256
#
# --- Multi-aggregator routing (Phase 3; optional) ---
# Provider order for DEX swaps. Default: 0x only.
# Supported: 0x, 1inch, openocean
# DEX_SWAP_PROVIDERS=0x,1inch,openocean
#
# 1inch requires an API key:
# ONEINCH_API_KEY=...
# ONEINCH_API_VERSION=v6.1
#
# OpenOcean tuning:
# OPENOCEAN_GAS_PRICE_WEI=1000000000
#
# --- Circuit breaker (recommended) ---
# SWAP_BREAKER_ENABLED=true
# SWAP_BREAKER_FAIL_THRESHOLD=5
# SWAP_BREAKER_OPEN_MS=20000
#
# --- DEX safety (recommended for production) ---
# Default slippage when client omits it (0.01 = 1%)
# DEX_DEFAULT_SLIPPAGE_PCT=0.01
# Hard cap to prevent unsafe quotes (0.03 = 3%)
# DEX_MAX_SLIPPAGE_PCT=0.03

# --- DEX swap telemetry (Phase 2; optional) ---
# Writes rows to dex_swap_events (requires DB + migrations).
# DEX_SWAP_TELEMETRY_ENABLED=true

# --- DEX pair activation (no code deploy) ---
# After Pancake (or other) AMM liquidity exists and 0x can route, promote LDX pairs for
# /v1/markets/pairs + /v1/pairs. Symbols must match shared/pairs.js (e.g. LDX/USDT).
# Restart the backend after changing. 0x still needs real on-chain liquidity — see docs/dex-env.md
# DEX_ACTIVE_PAIR_SYMBOLS=LDX/USDT,LDX/BNB,LDX/ETH
#
# Also merge active rows from table dex_pair_activations (no restart). Set false for env-only promos.
# DEX_PAIR_DB_ACTIVATION_ENABLED=true
# Admin: GET/POST/DELETE /v1/admin/dex-pairs/activations (same ADMIN_API_KEY as listings).
#
# Optional: record Pancake pair contract addresses (0x does not use these for quotes).
# Pattern: DEX_POOL_<CHAIN>_<BASE>_<QUOTE>=0x...
# DEX_POOL_BSC_LDX_USDT=0x
# DEX_POOL_BSC_LDX_BNB=0x
# DEX_POOL_BSC_LDX_ETH=0x
#
# --- DEX routability filter (optional; hide pairs with no 0x route) ---
# When enabled, markets endpoints will probe 0x with tiny quotes (cached) and automatically
# remove (or demote) pairs where `liquidityAvailable=false` or quotes error.
#
# DEX_ROUTABILITY_FILTER_ENABLED=true
# Optional: include per-pair `routableOn0x` + `routability0x` fields in `GET /v1/markets/pairs`.
# DEX_ROUTABILITY_INCLUDE_FIELD=true
# DEX_ROUTABILITY_CHAIN_ID=56
# Multi-chain probe list (overrides DEX_ROUTABILITY_CHAIN_ID when set)
# DEX_ROUTABILITY_CHAIN_IDS=56,1
# Use 0x /price (faster) for routability checks (recommended)
# DEX_ROUTABILITY_USE_PRICE=true
# DEX_ROUTABILITY_CACHE_MS=300000
# DEX_HIDE_UNROUTABLE_PAIRS=true
#
# Background prefetch to warm routability cache (recommended if include/filter enabled)
# DEX_ROUTABILITY_PREFETCH_ENABLED=true
# DEX_ROUTABILITY_PREFETCH_INTERVAL_MS=180000
#
# --- Phase 6: multi-chain expansion (Option A: independent liquidity per chain) ---
# After deploying LDX on additional chains, record addresses here for ops/reference.
# Note: the swap UI uses token presets from `@lidex/shared` today; updating these envs alone
# does not automatically update frontend token lists unless you also update presets.
# LDX_ADDRESS_ETH=0x...
# LDX_ADDRESS_POLYGON=0x...
# LDX_ADDRESS_AVALANCHE=0x...
# LDX_ADDRESS_ARBITRUM=0x...
#
# The backend exposes these overrides to the UI via:
# GET /v1/tokens/presets?chainId=56

# --- Phase 2: LDX presale (optional; API GET /v1/presale; /presale page sends txs in-wallet) ---
# PRESALE_ACTIVE=true
# PRESALE_CONTRACT_BSC=0xYourPresaleContract
# PRESALE_URL=https://your-partner-or-app.example/presale
# PRESALE_CHAIN_ID=56
# PANCAKE_ADD_LIQUIDITY_PREFIX=https://pancakeswap.finance/v2/add
#
# On-chain buy panel (must match your presale contract ABI):
# PRESALE_PAYMENT_MODE=erc20   # or native (BNB/ETH value sent with tx)
# PRESALE_PAYMENT_TOKEN=       # optional; defaults to preset USDT on chain
# PRESALE_PAYMENT_SYMBOL=USDT  # optional if token is in shared presets
# PRESALE_PAYMENT_DECIMALS=18  # optional if not in presets
# PRESALE_NATIVE_SYMBOL=BNB    # label only when PAYMENT_MODE=native
# PRESALE_PURCHASE_FN=buyTokens # erc20 default; native default is buy — must exist on contract
#
# Countdown / buy window (optional; overrides contract if set). Unix seconds.
# PRESALE_START_UNIX=1700000000
# PRESALE_END_UNIX=1701000000
# Read startTime()/endTime() from presale contract via PRESALE_RPC_URL (defaults per chain). Set false to skip.
# PRESALE_READ_SCHEDULE_FROM_CONTRACT=true
# PRESALE_RPC_URL=https://bsc-dataseed.binance.org/
# If your getters differ: PRESALE_TIME_START_FN=startTime PRESALE_TIME_END_FN=endTime

# --- Phase 4: internal liquidity pools (DB; GET/POST /v1/cex/liquidity/*) ---
# Pool row for CEX_MATCHER_SYMBOL is auto-created with zero reserves. LP add/remove off by default:
# CEX_LIQUIDITY_ENABLED=true
# Route unmatched **market** IOC remainder through the internal CPAMM (needs LP reserves + total LP > 0):
# CEX_POOL_MATCHING_ENABLED=true
# Optional fee hint (metadata; swap fee inside pool not implemented in v1 matcher):
# CEX_LIQUIDITY_POOL_FEE_BPS=10
# LP rewards (pro-rata by LP share; credits internal balance + ledger kind liquidity_reward on claim):
# CEX_LIQ_REWARD_ASSET=LDX
# CEX_LIQ_REWARD_RATE_PER_SECOND=0.1
# Phase 8 — time-bounded campaigns that multiply LP reward emission (piecewise accrual). Set false to disable module + admin APIs.
# LIQ_MINING_ENABLED=true
# Phase 8 — CEX governance signaling (weighted polls on custodial LDX / staked LDX). Non-binding; set false to disable.
# GOVERNANCE_SIGNAL_ENABLED=true
#
# --- Phase 3: internal CEX matcher (single pair, no 0x) ---
# P8-M4: POST /v1/cex/orders { clientOrderId } (optional, unique per user); GET /v1/cex/orders?status=active&bookOnly=true;
# POST /v1/cex/orders/cancel-all { includePendingStop?: boolean } — requires migration cex_orders_p8_m4 (post_only, client_order_id).
# P8-M5 — isolated margin (synthetic; INTERNAL mark only). Keep false until risk + legal approve.
# MARGIN_ENABLED=false
# MARGIN_MAX_LEVERAGE=5
# MARGIN_MIN_COLLATERAL_QUOTE=5
# MARGIN_MAINTENANCE_BPS=100
# MARGIN_MAX_OPEN_PER_USER=4
# MARGIN_LIQUIDATION_EXTRA_FEE_BPS=0
# CEX_MATCHER_SYMBOL=LDX/USDT
# Paper balances: POST /v1/cex/dev/fund (auth) — disable in production.
# CEX_DEV_FUNDING=true
#
# Simulated deposit/withdraw (+ audit rows in cex_ledger_entries). Pair assets only (e.g. LDX, USDT).
# POST /v1/cex/deposit  POST /v1/cex/withdraw  GET /v1/cex/ledger
# CEX_PAPER_TRANSFERS=true
#
# Taker fee on each fill (receive-side): buy → fee in base; sell → fee in quote. Basis points, max 5000.
# CEX_FEE_BPS=10
# Credits fees to this wallet’s custodial user (getOrCreate). If unset, fee is burned (not credited).
# CEX_FEE_TREASURY_ADDRESS=0xYourTreasuryWallet
#
# Phase 5 — staking → benefits (defaults on). Tier feeBps = lower taker fee cap vs CEX_FEE_BPS; tier referralBoostBps adds to referrer’s DEX swap share (integrator fee).
# CEX_STAKE_ASSET=LDX
# CEX_STAKING_FEE_DISCOUNT_ENABLED=true
# CEX_STAKING_REFERRAL_BOOST_ENABLED=true
#
# Min limit order size (optional; quote notional = price × quantity in USDT/terms of quote asset)
# CEX_MIN_NOTIONAL_QUOTE=10
# CEX_MIN_QTY_BASE=1
#
# --- On-chain CEX bridge (ERC-20 deposit by tx hash + hot-wallet withdraw) ---
# Deposits: user sends from their logged-in wallet address to CEX_DEPOSIT_ADDRESS, then POST /v1/cex/onchain/deposit/confirm { txHash }.
# Read-only: GET /v1/cex/onchain/deposit/status?txHash=… (confirmations / match / credited), GET /v1/cex/onchain/deposits (history).
# Withdraws: debits internal balance, hot wallet sends ERC-20 to the same wallet address. Never commit CEX_HOT_WALLET_PRIVATE_KEY.
# CEX_ONCHAIN_ENABLED=true
# CEX_ONCHAIN_CHAIN_ID=56
# CEX_ONCHAIN_RPC_URL=https://bsc-dataseed.binance.org
# Optional block explorer base for UI links (Etherscan-style /address/, /tx/, /token/).
# CEX_BLOCK_EXPLORER_URL=https://bscscan.com
# CEX_ONCHAIN_MIN_CONFIRMATIONS=15
# CEX_DEPOSIT_ADDRESS=0xYourTreasuryOrDepositWallet
# Per-asset token contracts (symbols must match CEX_MATCHER_SYMBOL parts, e.g. LDX, USDT):
# CEX_TOKEN_USDT_ADDRESS=0x...
# CEX_TOKEN_USDT_DECIMALS=18
# CEX_TOKEN_LDX_ADDRESS=0x...
# CEX_TOKEN_LDX_DECIMALS=18
# CEX_HOT_WALLET_PRIVATE_KEY=0x...   # optional; omit to allow deposit-only
#
# Auto-detect deposits: scan ERC-20 Transfer logs to CEX_DEPOSIT_ADDRESS (requires DB tables from migration 20260409120000).
# CEX_ONCHAIN_DEPOSIT_POLLER=true
# CEX_ONCHAIN_POLL_INTERVAL_MS=45000
# CEX_ONCHAIN_LOG_BLOCK_CHUNK=2000
# CEX_ONCHAIN_FROM_BLOCK=   # optional first block when initializing cursor (default: safeHead − 10_000)
#
# GET /v1/cex/onchain/treasury — if hot wallet native (ETH/BNB/etc.) is below this, response includes warnings[] (float, human units).
# CEX_TREASURY_WARN_NATIVE_ETH=0.05

# Public URL of the Next.js app (no trailing slash). Used for referral share links in emails/API.
# Example: https://app.example.com  |  dev: http://localhost:3001
APP_PUBLIC_URL=http://localhost:3001

# Comma-separated browser origins allowed to call the API with credentials (CORS).
# Must include your Next.js origin(s), e.g. https://app.example.com
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Session cookie: Secure flag defaults to true when NODE_ENV=production.
# Override: COOKIE_SECURE=true|false
# Optional: COOKIE_DOMAIN=.example.com

# Rate limits (per IP): auth = 15 min window; swap quote/execute = 1 min window
# RATE_LIMIT_AUTH_MAX=30
# RATE_LIMIT_SWAP_QUOTE_MAX=45
# RATE_LIMIT_SWAP_EXECUTE_MAX=30
# RATE_LIMIT_REFERRAL_MAX=120
# CEX mutations: place/cancel order, dev fund, deposit/withdraw (per user id when logged in, else IP; 1 min window)
# RATE_LIMIT_CEX_WRITE_MAX=90
# Phase 7: token listing application (per IP; 1 hour window)
# RATE_LIMIT_LISTING_APPLY_MAX=25
#
# Automated TOKEN/LDX registry listing (no admin UI): when true, applications with pairWithLdx
# run on-chain checks and may upsert listed_tokens immediately.
# LISTING_AUTO_LDX_ENABLED=true
# Minimum totalSupply() in raw units (smallest token units), e.g. 1e24 = 1_000_000 tokens at 18 decimals
# LISTING_MIN_TOTAL_SUPPLY_RAW=1000000000000000000000000
# Optional per-chain JSON-RPC (recommended in production). Falls back to public defaults for known chains.
# LISTING_RPC_137=https://polygon-rpc.com/
# LISTING_RPC_1=https://...
# LISTING_RPC_56=https://bsc-dataseed.binance.org/
# If false, symbol/decimals on the form are not required to match chain (chain values still written to registry).
# LISTING_AUTO_REQUIRE_METADATA_MATCH=true
#
# Notify admin / ops on each listing application (POST JSON). Optional HMAC: LISTING_ADMIN_WEBHOOK_SECRET → header X-Lidex-Signature: sha256=<hex>
# LISTING_ADMIN_WEBHOOK_URL=https://hooks.slack.com/services/...
# LISTING_ADMIN_WEBHOOK_SECRET=
#
# Department admin API (list applications & registry rows). No UI in this repo — use curl or your internal dashboard.
# Send: Authorization: Bearer <key>  or  X-Admin-Key: <key>
# GET /v1/admin/listings/applications?status=submitted&limit=50&cursor=
# GET /v1/admin/listings/applications/:id
# GET /v1/admin/listings/tokens?chainId=56&limit=100&cursor=
# GET /v1/admin/dex-pairs/activations
# POST /v1/admin/dex-pairs/activations  body: {"symbol":"LDX/USDT","active":true,"note":"…"}
# DELETE /v1/admin/dex-pairs/activations?symbol=LDX%2FUSDT
#
# Phase 8 — launchpad (CEX): payAsset must match CEX quote (e.g. USDT). Public GET /v1/launchpad/sales, POST .../participate
# GET /v1/admin/launchpad/sales  POST  PATCH /v1/admin/launchpad/sales/:id
# LAUNCHPAD_ENABLED=true
# ADMIN_API_KEY=generate-a-long-random-secret
#
# Phase F — optional scoped keys (if set, replaces ADMIN_API_KEY for auth). Example:
# ADMIN_API_KEYS_JSON=[{"key":"super-secret-1","roles":["super"]},{"key":"listings-read","roles":["listings"]},{"key":"treasury","roles":["treasury_read"]},{"key":"auditor","roles":["audit_read"]}]
#
# Phase F — optional IP allowlist (comma-separated IPv4 or CIDR). Requires TRUST_PROXY behind a load balancer.
# ADMIN_IP_ALLOWLIST=127.0.0.1,10.0.0.0/8

# Phase G — manual CEX available-balance adjustment (HIGH RISK). POST /v1/admin/cex/ledger/manual-adjust
# requires super key, X-Admin-Approver-Key (second key), matching X-Support-Ticket-Id + body.ticketId.
# Unset or false = endpoint returns 403 DISABLED.
# ADMIN_MANUAL_LEDGER_ENABLED=true
#
# Behind nginx/ELB: TRUST_PROXY=1 so admin audit logs capture client IP (see docs/admin-plan.md).
# TRUST_PROXY=1

# Hybrid mode: callers must send header `X-Lidex-Mode: dex` or `cex` (or cookie `lidex_mode` on same site).
# DEX-only: /v1/swap/*, /v1/referral/ledger/confirm. CEX/internal: /v1/markets/candles, /v1/fees/*, /v1/pairs.
# Shared (any mode): /v1/markets/pairs, /v1/markets/stats, /v1/referral/* except confirm. /v1/auth/* has no mode gate.

# Platform fee (0x Swap API v2 integrator fee)
# 50 bps = 0.5%
SWAP_FEE_RECIPIENT=0xYourFeeWalletAddress
SWAP_FEE_BPS=50
# Choose ONE: buyToken or sellToken
SWAP_FEE_TOKEN=buyToken

