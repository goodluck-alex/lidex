NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Optional: higher rate limits for the homepage USD market snapshot (/api/markets/coingecko).
# COINGECKO_API_KEY=
# Optional: get a real id at https://cloud.walletconnect.com — if unset, RainbowKit uses a built-in demo id.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Internal admin UI (/internal-admin) — server only; never use NEXT_PUBLIC_ for these ---
# Same value as backend ADMIN_API_KEY. Required for console data and mutations.
# ADMIN_API_KEY=
# Gate who can open the UI (production requires this). Not the same as staff JWT/OIDC (Phase F).
# INTERNAL_ADMIN_UI_PASSWORD=
# Optional: override backend URL for server-side fetches only (defaults to NEXT_PUBLIC_BACKEND_URL).
# BACKEND_URL=http://localhost:4000
#
# Optional Phase G: second key for dual-control audit on listing review (must differ from ADMIN_API_KEY).
# ADMIN_CONSOLE_APPROVER_KEY=

